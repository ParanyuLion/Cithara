# Copy this file to .env and fill in your real values.
# Do not commit .env to source control.
GENERATOR_STRATEGY = mock
SUNO_API_BASE_URL=https://api.sunoapi.org
SUNO_API_KEY=your_suno_api_key_here
SUNO_MODEL=V4_5
SUNO_CALLBACK_URL=

# Google OAuth (required for login)
# Setup: https://console.cloud.google.com/
# 1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorized redirect URI: http://127.0.0.1:8000/accounts/google/login/callback/
# 4. Copy Client ID and Secret below
# 5. In Django admin (/admin/) → Social applications → Add → Google, paste credentials, add site
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
